{
  "name": "vista-do-bosque-monorepo",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @vista/api start:dev",
    "dev:web": "pnpm --filter @vista/web dev",
    "db:migrate": "pnpm --filter @vista/database prisma migrate dev",
    "db:push": "pnpm --filter @vista/database prisma db push",
    "db:studio": "pnpm --filter @vista/database prisma studio"
  },
  "engines": { "node": ">=18.18.0", "pnpm": ">=8.0.0" }
}
